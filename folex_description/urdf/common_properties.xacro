<?xml version="1.0"?>
<robot name="common_properties" xmlns:xacro="http://ros.org/wiki/xacro">

	<!-- Properties -->
	<xacro:property name="pi" value="3.1415926"/>
	
	<!-- Color -->
	<material name="black">
		<color rgba="0.0 0.0 0.0 1.0"/>
  </material>

	<material name="gray">
		<color rgba="0.0 0.0 0.0 1.0"/>
  </material>


</robot>
